<section class="max-width page-p d-flex flex-col my-2 gap-1 center">
	<h1>{{t 'pages.team.h1'}}</h1>
	<div class="intro-text">
	<p>{{t 'pages.team.intro-1'}}</p>
	<p>{{t 'pages.team.intro-2'}}</p>
	</div>
</section>
<p>{{base}}</p>
<section id='team' class='max-width page-p d-flex flex-col my-2 gap-1 center'>
	<div class='d-flex flex-wrap justify-center align-stretch gap-1 w-100'>
		{{#each team.members}}
		{{#with (lookup ../team.cards this)}}
		{{> team}}
		{{/with}}
		{{/each}}	</div>
</section>
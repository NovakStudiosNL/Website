{{#with (lookup projects.pages key) as |project|}}
<article
	id="project-page"
	style="background-image: url('{{@root.base}}src/img/projects/{{project.img_files }}/background-30.png');"
	class="w-100"
>
	<section
		id="hero"
		style="background-color:{{project.hero_color}}; border-bottom:{{project.hero_stroke}};"
		class="w-100 d-flex flex-col center"
	>
		<div class="max-width page-p d-flex flex-col my-2 gap-1">
			<p style="color:{{project.hero_text_color}};" class="small">
				<span>
					<a href="{{@root.base}}index.html" class="breadcrumb">Home</a>
				</span>
				/
				<span>
					<a href="{{@root.base}}src/pages/projects.html" class="breadcrumb">
						Projects
					</a>
				</span>
				/
				<span>
					{{tVariables 'pages.projects.${project}.title'
					project=project.locale_file }}
				</span>
			</p>

			<div class="cover {{project.collab_overlap}}">
				{{#if project.collab}}
				<div class="collab d-flex flex-col center">
					<h5 style="color:{{project.hero_text_color}};">
						In collaboration with:
					</h5>
					<img
						src="{{@root.base}}src/img/projects/{{project.img_files }}/collab.png"
					/>
				</div>
				{{/if}}
				<img
					class="w-100"
					src="{{@root.base}}src/img/projects/{{project.img_files }}/cover.png"
				/>
			</div>

			<div class="d-flex flex-col gap-1 center">
				<h3
					style="color:{{project.hero_text_color}};"
					class="upper text-center"
				>
					{{tVariables 'pages.projects.${project}.tagline'
					project=project.locale_file }}
				</h3>
				<p style="color:{{project.hero_text_color}};" class="text-center">
					{{tVariables 'pages.projects.${project}.description'
					project=project.locale_file }}
				</p>
			</div>
		</div>
	</section>
</article>
{{/with}}
